:DataService a sh:NodeShape ;
    sh:property [ a sh:PropertyShape ;
            sh:maxCount 2 ;
            sh:minCount 2 ;
            sh:node :Dataset ;
            sh:path dcat:servesDataset ],
        [ a sh:PropertyShape ;
            sh:in ( schema:WebAPI ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path rdf:type ],
        [ a sh:PropertyShape ;
            sh:in ( dcat:DataService ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path rdf:type ],
        [ a sh:PropertyShape ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:path dcat:endpointURL ],
        [ a sh:PropertyShape ;
            sh:dataType xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path rdfs:label ] ;
    sh:targetClass dcat:DataService .

